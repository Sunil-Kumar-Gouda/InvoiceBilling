## LocalStack settings for InvoiceBilling (local development)
##
## Used by docker-compose.localstack.yml and the LocalStack init scripts.

LOCALSTACK_SERVICES=s3,sqs
AWS_DEFAULT_REGION=ap-south-1
SQS_ENDPOINT_STRATEGY=path

INVOICEBILLING_S3_BUCKET=invoicebilling-invoices
INVOICEBILLING_SQS_QUEUE=invoicebilling-jobs
